# Normalize line endings so the same bytes land on every platform + in CI.
* text=auto eol=lf

# Windows batch + the Gradle Windows wrapper must be CRLF.
*.bat text eol=crlf

# The POSIX Gradle wrapper must stay LF (CI runs ./gradlew on Linux).
gradlew text eol=lf

# Binary assets — never touch line endings.
*.jar binary
*.apk binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
