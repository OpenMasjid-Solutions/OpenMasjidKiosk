  Data extraction rules (Android 12+): disallow both cloud backup and device-to-device
  transfer. A kiosk's tokens/config are device-bound and must not be copied off it.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
    </device-transfer>
</data-extraction-rules>
