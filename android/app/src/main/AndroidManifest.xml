<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Bring the kiosk up automatically after a reboot (a wall tablet should self-heal). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!--
      Slice 4 networking: the tablet talks HTTPS to the LAN server (pairing, heartbeats,
      config, logs) and — in later slices — to Stripe. ACCESS_NETWORK_STATE lets WorkManager's
      CONNECTED constraint and our "internet down" messaging read connectivity. Everything is
      OUTBOUND only; nothing is exposed inbound.
    -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Remote app update: download the server's APK and launch the installer. On a non-device-
         owner tablet the system shows a one-tap confirm (an app can't self-update silently). -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!--
      Slice 5 — Stripe Reader M2 (Bluetooth + USB). The Terminal SDK needs these; they are
      requested-and-explained ONLY inside the PIN-protected maintenance screen, never in the
      donor flow. Pairing uses a typed 6-digit code (no camera/QR), so no CAMERA permission.
        - Bluetooth on API 31+: BLUETOOTH_SCAN (neverForLocation) + BLUETOOTH_CONNECT
        - Bluetooth pre-31: legacy BLUETOOTH/BLUETOOTH_ADMIN + ACCESS_FINE_LOCATION (BLE scan)
        - Location: still required by the SDK for ALL discovery configs (location must be ON)
        - USB: android.hardware.usb.host feature (the SDK prompts for the USB device at connect)
      The Terminal SDK contributes its own foreground service + FOREGROUND_SERVICE permissions
      via manifest merging, so we don't declare those here.
    -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false" />
    <uses-feature android:name="android.hardware.usb.host" android:required="false" />

    <application
        android:name=".KioskApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.OpenMasjidKiosk">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.OpenMasjidKiosk">

            <!-- Standard launcher entry. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
              Act as the device HOME launcher (§10): the tablet boots straight into the
              kiosk and Home goes nowhere else. HOME + DEFAULT are what the system needs
              to offer this activity as a launcher.
            -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Serves the downloaded APK to the system installer as a content:// URI (file:// is
             blocked on modern Android). Authority must match AppUpdater. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Restart the kiosk after a reboot, even when not provisioned as device owner. -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!--
          Device admin receiver — required for Lock Task Mode (true kiosk) once the tablet
          is provisioned as device owner via a one-time ADB step (see docs/TABLET_SETUP.md,
          later slice). No policies are used yet; the presence of the receiver + device_admin
          metadata is what device-owner provisioning needs.
        -->
        <receiver
            android:name=".KioskAdminReceiver"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
